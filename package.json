{
  "name": "setup-cos",
  "version": "1.0.0",
  "description": "GitHub Action to install the Cosine CLI (cos)",
  "main": "src/main.ts",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "package": "ncc build src/main.ts -o dist --minify --license licenses.txt",
    "format": "prettier --write 'src/**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.3"
  }
}
